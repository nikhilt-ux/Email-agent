# ─── Streamlit Cloud Secrets Template ───────────────────────────────────────
# Copy this file to .streamlit/secrets.toml on your local machine,
# then paste the contents into the Streamlit Cloud dashboard under App → Settings → Secrets.
#
# HOW TO GET THESE VALUES:
#   1. Run the app locally once: it will open a browser OAuth screen and write token.json
#   2. Open token.json — paste all its key/value pairs under [google_token] below
#   3. Open credentials.json → "installed" section — paste under [google_credentials]
#   4. Copy the whole file into Streamlit Cloud → App Settings → Secrets
# ─────────────────────────────────────────────────────────────────────────────

[google_token]
# Paste all fields from your token.json here:
token         = "ya29.XXXXX..."
refresh_token = "1//XXXXX..."
token_uri     = "https://oauth2.googleapis.com/token"
client_id     = "XXXXX.apps.googleusercontent.com"
client_secret = "XXXXX"
scopes        = ["https://www.googleapis.com/auth/gmail.readonly", "https://www.googleapis.com/auth/spreadsheets"]
expiry        = "2025-01-01T00:00:00Z"

[google_credentials]
# Paste the "installed" block from your credentials.json here:
client_id     = "XXXXX.apps.googleusercontent.com"
client_secret = "XXXXX"
auth_uri      = "https://accounts.google.com/o/oauth2/auth"
token_uri     = "https://oauth2.googleapis.com/token"
redirect_uris = ["http://localhost"]
